{
	"compilerOptions": {
		"target": "es2020",
		"module": "esnext",
		"moduleResolution": "node",

		"rootDir": "./src",
		"outDir": "./dist",

		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,

		"declaration": true,
		"declarationMap": false,
		"sourceMap": false,

		"types": ["node"],

		"isolatedModules": false,
		"verbatimModuleSyntax": false
	},
	"include": ["src/**/*"]
}
