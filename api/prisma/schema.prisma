datasource db {
    provider = "postgresql"
    url = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

model User {
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt()
    id String @id() @default(uuid())
    email String @unique()
    name String
    password String
}