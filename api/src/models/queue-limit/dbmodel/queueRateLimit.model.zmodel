import "../../base/base.model.zmodel";
import "../../queue/dbmodel/queue.model.zmodel"

model QueueRateLimiter extends Base {

    id String @id @default(uuid())
    job_count Int @default(0)
    last_reset_at DateTime?
    
    queue Queue @relation("QueueRateLimiter", fields: [queue_id], references: [id])
    queue_id String @unique

    @@index([queue_id]) // for quick lookup by queue_id in job rate limiter middleware
}