
import "../../base/base.model.zmodel";
import "../../project/dbmodel/project.model.zmodel";

model User extends Base {
    
    id String @id @default(uuid())
    email String @unique
    name String
    password String
    project Project[] @relation("UserProjects")

    @@allow('create', true)
    @@allow('read', auth() == this)
}

