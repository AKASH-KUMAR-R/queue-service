import "./src/models/user/dbmodel/user.model.zmodel";
import "./src/models/cron-state/dbmodel/cronState.model.zmodel";

datasource db {
    provider = 'postgresql'
    url = env('DATABASE_URL')
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-cli"
  moduleFormat  = "esm"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}
